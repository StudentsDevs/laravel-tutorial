#!/bin/sh
# Pre-push hook to prevent pushes to main from feature branches
# and prevent direct pushes without creating a PR

remote="$1"
url="$2"

# Get current branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Check if trying to push to main
if [ "$CURRENT_BRANCH" = "main" ]; then
  echo "❌ ERROR: You cannot push directly to main!"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "Please follow this workflow:"
  echo ""
  echo "1. Create a feature branch:"
  echo "   git checkout -b feature/your-feature"
  echo ""
  echo "2. Make your changes and commit:"
  echo "   git commit -m 'feat: your changes'"
  echo ""
  echo "3. Push to your feature branch:"
  echo "   git push origin feature/your-feature"
  echo ""
  echo "4. Create a Pull Request on GitHub"
  echo ""
  echo "5. Once approved, PR can be merged to main"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  exit 1
fi

# Check if branch name follows conventional naming (feature/, fix/, docs/, etc.)
if ! echo "$CURRENT_BRANCH" | grep -qE '^(feature|fix|docs|style|refactor|perf|test|chore|ci|hotfix)/'; then
  echo "⚠️  WARNING: Branch name should follow convention"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "Current branch: $CURRENT_BRANCH"
  echo ""
  echo "Recommended format: <type>/<description>"
  echo "Examples:"
  echo "  ✅ feature/user-authentication"
  echo "  ✅ fix/login-bug"
  echo "  ✅ docs/readme-update"
  echo ""
  echo "Types: feature, fix, docs, style, refactor, perf, test, chore, ci, hotfix"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  
